        "set_humidity": {
          "description": "设置目标湿度",
          "operation": "change_humidity_threshold",
          "params": {
            "humidity": {
              "type": "integer",
              "range": [30, 90],
              "unit": "%",
              "description": "目标湿度值"
            }
          }
        }
      },
      "keywords": ["空调", "温度", "湿度", "制冷", "制热", "凉爽", "温暖", "干燥", "潮湿"]
